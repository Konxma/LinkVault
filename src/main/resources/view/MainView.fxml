<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600" prefWidth="900" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.konxma.linkvault.ui.MainController">
  <left>
    <VBox prefWidth="220" spacing="10" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-width: 0 1 0 0;">
      <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Мої папки" />
      <ListView fx:id="categoryListView" VBox.vgrow="ALWAYS" />
      <Button maxWidth="Infinity" onAction="#handleAddCategory" style="-fx-background-color: #e0e0e0;" text="+ Нова папка" />
    </VBox>
  </left>
  <center>
    <VBox spacing="15" style="-fx-padding: 15;">
      <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="currentCategoryLabel" style="-fx-font-weight: bold; -fx-font-size: 20px;" text="Оберіть папку зліва" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleAddLink" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="+ Додати посилання" />
        <Button onAction="#handleDeleteLink" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Видалити" />
      </HBox>
      <TableView fx:id="linksTable" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="titleColumn" prefWidth="200" text="Назва закладки" />
          <TableColumn fx:id="urlColumn" prefWidth="250" text="URL-адреса" />
          <TableColumn fx:id="tagsColumn" prefWidth="200" text="Теги" />
        </columns>
        <columnResizePolicy>
          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
      </TableView>
    </VBox>
  </center>
</BorderPane>